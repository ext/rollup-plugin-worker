{
  "name": "@sidvind/rollup-plugin-worker",
  "version": "2.0.0",
  "description": "Rollup plugin to import a worker and get the worker URL",
  "keywords": [
    "rollup",
    "worker"
  ],
  "homepage": "https://github.com/ext/rollup-plugin-worker",
  "bugs": {
    "url": "https://github.com/ext/rollup-plugin-worker/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ext/rollup-plugin-worker.git"
  },
  "license": "MIT",
  "author": "David Sveningsson <ext@sidvind.com>",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "workspaces": [
    "tests/*"
  ],
  "scripts": {
    "prebuild": "tsc",
    "build": "node build.js",
    "eslint": "eslint --cache .",
    "eslint:fix": "eslint --cache --fix .",
    "prepack": "release-prepack package.json --bundle",
    "postpack": "release-postpack package.json",
    "prepare": "husky",
    "prepublishOnly": "release-prepublish package.json --bundle",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "postpublish": "release-postpublish package.json",
    "pretest": "npm run prettier:check && npm run eslint",
    "test": "npm run --workspaces test"
  },
  "commitlint": {
    "extends": "@html-validate"
  },
  "prettier": "@html-validate/prettier-config",
  "dependencies": {
    "magic-string": "0.30.21"
  },
  "devDependencies": {
    "@html-validate/commitlint-config": "4.3.0",
    "@html-validate/eslint-config": "9.13.1",
    "@html-validate/eslint-config-typescript": "9.13.3",
    "@html-validate/eslint-config-typescript-typeinfo": "9.13.3",
    "@html-validate/prettier-config": "4.1.8",
    "@html-validate/release-scripts": "7.3.6",
    "@microsoft/api-extractor": "7.58.12",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "22.19.19",
    "@typescript/native": "npm:typescript@7.0.2",
    "esbuild": "0.28.1",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "npm-pkg-lint": "5.2.0",
    "rollup": "4.62.2",
    "typescript": "npm:@typescript/typescript6@6.0.2"
  },
  "peerDependencies": {
    "rollup": "^4.0.0"
  },
  "engines": {
    "node": "^22.16.0 || >= 24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "allowScripts": {
    "@html-validate/commitlint-config": true,
    "esbuild": true,
    "fsevents": false,
    "unrs-resolver": true
  },
  "renovate": {
    "extends": [
      "gitlab>html-validate/renovate-config"
    ]
  }
}
